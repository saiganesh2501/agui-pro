# Copy to .env and paste your key. NEVER commit the real .env.
OPENAI_API_KEY=sk-your-key-here
# Get the keys from your local Langfuse UI (http://localhost:3000) →
# Settings → API Keys, after creating a project.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=http://localhost:3000

